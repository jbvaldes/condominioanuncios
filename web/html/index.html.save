 space-between;
      align-items: center;
      padding: 0.8rem 1.5rem;
      background: rgba(0,0,0,0.85);
      border-bottom: 2px solid #555;
    }
    .logo-box {
      font-size: clamp(0.8rem, 1.8vw, 1.3rem);
      font-weight: 700;
      color: #ccc;
      background: #222;
      padding: 0.3rem 0.8rem;
      border-radius: 4px;
    }
    .main {
      flex: 1;
      position: relative;
      background: #000;
    }
    .slide {
      position: absolute;
      top: 0; left: 0;
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 1.5rem;
      opacity: 0;
      transition: opacity 0.5s ease-in-out;
      pointer-events: none;
    }
    .slide.active {
      opacity: 1;
      pointer-events: auto;
    }
    .slide h2 {
      font-size: clamp(1.2rem, 2.8vw, 2rem);
      font-weight: 700;
      margin-bottom: 1rem;
      color: #ddd;
    }
    .anuncio-texto {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 700;
      line-height: 1.3;
      text-shadow: 1px 1px 2px black;
      margin-bottom: 0.8rem;
      word-wrap: break-word;
    }
    .anuncio-fecha {
      font-size: clamp(0.9rem, 2vw, 1.3rem);
      color: #ccc;
      margin-bottom: 1rem;
    }
    .reloj {
      font-size: clamp(1rem, 2.8vw, 1.8rem);
      color: #4fc3f7;
      font-weight: 700;
    }
    .recordatorio-texto {
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 700;
      line-height: 1.4;
    }
    .patrocinador-texto {
      font-size: clamp(1.5rem, 3.5vw, 2.5rem);
      font-weight: 700;
      color: #ffb74d;
    }
    .clima-texto {
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 700;
    }
    .evento-proximo {
      font-size: clamp(1rem, 2.5vw, 1.6rem);
      color: #ccc;
      margin-top: 0.8rem;
    }
    .comunidad-texto {
      font-size: clamp(1rem, 2.5vw, 1.6rem);
      color: #ccc;
      margin-bottom: 0.8rem;
    }
    .disclaimer {
      position: absolute;
      bottom: 0.5rem;
      left: 1rem;
      right: 1rem;
      background: rgba(255,0,0,0.85);
      color: white;
      font-size: clamp(0.7rem, 1.5vw, 1rem);
      font-weight: 700;
      text-align: center;
      padding: 0.3rem;
      border-radius: 6px;
      text-shadow: 1px 1px 2px black;
    }
    .footer {
      background: rgba(0,0,0,0.9);
      padding: 0.3rem;
      text-align: center;
      font-size: clamp(0.6rem, 1.2vw, 0.8rem);
      color: #888;
      border-top: 2px solid #555;
    }
    #pantalla.light { background: #f5f5f5; }
    #pantalla.light .header { background: #eee; border-color: #ccc; }
    #pantalla.light .logo-box { background: #ddd; color: #333; }
    #pantalla.light .footer { background: #eee; border-color: #ccc; color: #555; }
    #pantalla.light .slide h2 { color: #333; }
    #pantalla.light .anuncio-texto { text-shadow: none; }
    #pantalla.light .reloj { color: #0066cc; }
  </style>
